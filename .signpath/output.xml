<?xml version="1.0" encoding="utf-8"?>
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <!--
    Pass 2: signs the Velopack-generated installer plus the Update.exe stub
    inside the update nupkg. Segra.exe inside the nupkg is already signed
    from Pass 1, so it is not re-signed here.
  -->
  <zip-file>
    <pe-file path="Segra-win-Setup.exe">
      <authenticode-sign />
    </pe-file>
    <nupkg-file path="Segra-*-full.nupkg">
      <pe-file-set>
        <include path="lib/**/Update.exe" />
        <for-each>
          <authenticode-sign />
        </for-each>
      </pe-file-set>
    </nupkg-file>
  </zip-file>
</artifact-configuration>
